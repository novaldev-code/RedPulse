{
  "compilerOptions": {
    "target": "ES2022",
    "lib": ["ES2022", "DOM", "DOM.Iterable"],
    "strict": true,
    "skipLibCheck": true,
    "noUncheckedIndexedAccess": true,
    "esModuleInterop": true,
    "resolveJsonModule": true,
    "moduleDetection": "force",
    "allowSyntheticDefaultImports": true,
    "forceConsistentCasingInFileNames": true,
    "baseUrl": ".",
    "paths": {
      "@redpulse/db": ["packages/db/src/index.ts"],
      "@redpulse/validation": ["packages/validation/src/index.ts"],
      "@redpulse/ui": ["packages/ui/src/index.ts"]
    }
  }
}
